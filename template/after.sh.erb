# Wait for Positron Server to start
echo "$(date): Waiting for Positron Server to open port ${port}..."

if wait_until_port_used "${host}:${port}" 600; then
  echo "$(date): Discovered positron-server listening on port ${port}!"
else
  echo "$(date): Timed out waiting for Positron Server to open port ${port}!"
  clean_up 1
fi

sleep 2
