# Export the module function if it exists
[[ $(type -t module) == "function" ]] && export -f module

# Find available port to run server on
export port=$(find_port ${host})

# Export compute node the script is running on
export host="${host}"

# Generate connection token for authentication
export password="$(create_passwd 16)"

# Set Singularity Image
# TODO: Update this path once Positron container is built
export POSITRON_SERVER_IMAGE=<%= context.apptainer_image %>

# Set License Key File path for Positron activation
# TODO: Update this path to actual license location on DCC
export POSITRON_LICENSE_KEY_FILE="/opt/apps/licenses/positron/positron.lic"

# Is GPU Job?
<%- if context.num_gpus.to_s == "0" -%>
export gpu_job="no"
<%- else -%>
export gpu_job="yes"
<%- end -%>
