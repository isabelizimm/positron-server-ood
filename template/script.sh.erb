#!/usr/bin/bash -l

#Command Tracing
set -x

<%

# Set our working directory.
working_dir = Pathname.new(context.working_dir)

# Ensure that positron-server always starts up in either a user defined directory or the home directory.
if ! working_dir.exist?
    working_dir = Pathname.new(ENV['HOME'])
elsif working_dir.file?
    working_dir = working_dir.parent
end
%>

# Positron stores state in ~/.config/Positron
POSITRON_DATAROOT="$HOME/.config/Positron"
mkdir -p "$POSITRON_DATAROOT/extensions"

# Generate connection token file for authentication
echo "$password" > "$POSITRON_DATAROOT/connection-token"
chmod 600 "$POSITRON_DATAROOT/connection-token"

# Print compute node.
echo "$(date): Running on compute node ${compute_node}:$port"

#
# Start Positron Server.
#
echo "$(date): Started positron-server"
echo ""

# Setup Bind Mounts
BPath="$TMPDIR:/tmp"
BPath+=",/work:/work"
BPath+=",/cwork:/cwork"
BPath+=",/hpc/group:/hpc/group"
BPath+=",/hpc/dctrl:/hpc/dctrl"
<% if context.externalnfs.present? %>
# trigger automount for externalnfs if present
export NFSMOUNT=/nfs/<%= context.externalnfs %>
echo "NFSMOUNT is ${NFSMOUNT}"
ls /nfs/<%= context.externalnfs %>
BPath+=",${NFSMOUNT}:${NFSMOUNT}"
<% end %>

# Bind mount the license file for Positron activation
BPath+=",${POSITRON_LICENSE_KEY_FILE}:${POSITRON_LICENSE_KEY_FILE}:ro"

echo "BPath: $BPath"
echo ""
echo "Image: $POSITRON_SERVER_IMAGE"
echo "License: $POSITRON_LICENSE_KEY_FILE"
echo ""

echo "host: ${host}"
echo "port: ${port}"

export PORT=${port}
export WORKING_DIR="<%= working_dir.to_s %>"
export DATAROOT=$POSITRON_DATAROOT

# Launch Positron Server
echo "TIMING - Starting Positron Server at: $(date)"

# Positron uses connection-token-file for auth (not code-server's PASSWORD env var)
# --without-connection-token would skip auth entirely (not recommended)

if [ "$gpu_job" == "no" ]; then
  apptainer -vvv exec --bind="$BPath" "$POSITRON_SERVER_IMAGE" \
    positron-server \
    --host="0.0.0.0" \
    --port="$PORT" \
    --connection-token-file="$DATAROOT/connection-token" \
    --accept-server-license-terms \
    --extensions-dir="$DATAROOT/extensions" \
    --user-data-dir="$DATAROOT" \
    --telemetry-level="off" \
    --log="info" \
    "$WORKING_DIR"
else
  apptainer -vvv exec --nv --bind="$BPath" "$POSITRON_SERVER_IMAGE" \
    positron-server \
    --host="0.0.0.0" \
    --port="$PORT" \
    --connection-token-file="$DATAROOT/connection-token" \
    --accept-server-license-terms \
    --extensions-dir="$DATAROOT/extensions" \
    --user-data-dir="$DATAROOT" \
    --telemetry-level="off" \
    --log="info" \
    "$WORKING_DIR"
fi
